# Examples
#   node_modules                 # ignore node_modules folder
#   *.log                        # ignore all log files
#   .env                         # ignore single .env file
#   .env.local                   # ignore .env.local file
#   .venv/                       # ignore venv folder
#   __pycache__/                 # ignore python cache folder
#   .DS_Store                    # ignore macOS file system metadata
#   *.tmp                        # ignore temporary files
#   coverage/                    # ignore coverage reports
#   .vscode/                     # ignore VS Code settings
#   .idea/                       # ignore JetBrains IDE settings

